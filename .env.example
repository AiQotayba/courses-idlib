# Backend (apps/backend) — copy to apps/backend/.env
MONGODB_URI=mongodb://127.0.0.1:27017/courses
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d
PORT=4000
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Web + Admin — copy to apps/web/.env.local and apps/admin/.env.local
NEXT_PUBLIC_API_URL=http://localhost:4000

# Admin only — رابط الموقع العام (زر «فتح الموقع العام»)
NEXT_PUBLIC_WEB_APP_URL=http://localhost:3000

# Mobile — optional (Expo)
EXPO_PUBLIC_API_URL=http://localhost:4000
